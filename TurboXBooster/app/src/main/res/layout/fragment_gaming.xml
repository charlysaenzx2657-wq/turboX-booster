<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Stats rápidas para gaming -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/colorSurface"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ESTADO PARA GAMING"
                    android:textColor="@color/colorPrimary"
                    android:textSize="11sp"
                    android:letterSpacing="0.15"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="RAM libre"
                            android:textColor="@color/colorOnSurfaceVariant"
                            android:textSize="11sp"/>

                        <TextView
                            android:id="@+id/tv_ram_available"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-- MB"
                            android:textColor="@color/colorSecondary"
                            android:textSize="20sp"
                            android:fontFamily="sans-serif-bold"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Temperatura"
                            android:textColor="@color/colorOnSurfaceVariant"
                            android:textSize="11sp"/>

                        <TextView
                            android:id="@+id/tv_temp_current"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--°C"
                            android:textColor="@color/colorYellow"
                            android:textSize="20sp"
                            android:fontFamily="sans-serif-bold"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tv_game_readiness"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Calculando..."
                            android:textColor="@color/colorGreen"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium"
                            android:gravity="center"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Perfiles de rendimiento -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PERFIL DE RENDIMIENTO"
            android:textColor="@color/colorPrimary"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/colorSurface"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <com.google.android.material.chip.ChipGroup
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleSelection="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_battery"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔋 Ahorro"
                        style="@style/Widget.Material3.Chip.Filter"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_balanced"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚖️ Balanceado"
                        style="@style/Widget.Material3.Chip.Filter"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_performance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚡ Performance"
                        android:checked="true"
                        style="@style/Widget.Material3.Chip.Filter"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_extreme"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔥 Extremo"
                        style="@style/Widget.Material3.Chip.Filter"/>
                </com.google.android.material.chip.ChipGroup>

                <TextView
                    android:id="@+id/tv_profile_hint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔒 Los perfiles de rendimiento requieren Shizuku"
                    android:textColor="@color/colorOnSurfaceVariant"
                    android:textSize="12sp"
                    android:layout_marginTop="8dp"
                    android:visibility="gone"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_boost_now"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="🚀 APLICAR BOOST"
            android:textSize="15sp"
            android:fontFamily="sans-serif-bold"
            app:cornerRadius="12dp"
            android:layout_marginBottom="16dp"/>

        <!-- Lista de juegos -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TUS JUEGOS"
            android:textColor="@color/colorPrimary"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp"/>

        <ProgressBar
            android:id="@+id/progress_games"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/tv_no_games"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No se encontraron juegos instalados"
            android:textColor="@color/colorOnSurfaceVariant"
            android:textSize="14sp"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="gone"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_games"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"/>

    </LinearLayout>
</ScrollView>
